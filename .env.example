# ─── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (one of these is required)
DATABASE_URL=postgres://user:password@host:5432/dbname
# POSTGRES_URL=postgres://user:password@host:5432/dbname

# Session signing secret — MUST be set. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Cron endpoint authentication — MUST be set for production.
# Vercel sets this automatically for Vercel Cron; set manually for other deployments.
CRON_SECRET=

# ─── External Services ─────────────────────────────────────────────────────────

# ScrapingAnt API key for Booking.com scraping
SCRAPINGANT_API_KEY=

# Supabase (for screenshot storage)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Optional ─────────────────────────────────────────────────────────────────

# Override Amello API base URL (default: https://prod-api.amello.plusline.net/api/v1)
# AMELLO_BASE_URL=

# Booking.com cookies (alternative to storing in app_settings DB table)
# BOOKING_COM_COOKIES=

# Set to "no-verify" to disable SSL certificate validation on DB connection (NOT recommended)
# PGSSLMODE=

# Secret for /api/diag and /api/diag-env access (disabled in production without this)
# DIAG_SECRET=
